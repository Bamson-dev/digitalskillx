# ──────────────────────────────────────────────────────────────
# DigitalSkillX — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# Production: https://digitalskillx.com
# ──────────────────────────────────────────────────────────────

# Public site URL (auth redirects, certificate verify links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase ──────────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key

# Server-only secret. NEVER expose to the client / commit real value.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=re_your_key
EMAIL_FROM_NAME="DigitalSkillX"
EMAIL_FROM_ADDRESS=courses@digitalskillx.com

# ── YouTube Data API v3 ─────────────────────────────────────
YOUTUBE_API_KEY=your-youtube-data-api-key

# ── Claude AI Assistant ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Scheduled jobs (Vercel Cron) ──────────────────────────────
# Bearer secret required by /api/cron/* endpoints.
CRON_SECRET=generate-a-long-random-string
# Days of inactivity before a student is flagged / emailed.
INACTIVITY_DAYS=7

# ── Payments (future / v2) ────────────────────────────────────
PAYSTACK_SECRET_KEY=
FLUTTERWAVE_SECRET_KEY=
