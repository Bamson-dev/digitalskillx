# ──────────────────────────────────────────────────────────────
# DigitalSkillX — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# Production: https://digitalskillx.com
# ──────────────────────────────────────────────────────────────

# Public site URL (auth redirects, certificate verify links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase ──────────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key

# Server-only secret. NEVER expose to the client / commit real value.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ── Email (ZeptoMail SMTP) ────────────────────────────────────
ZEPTOMAIL_SMTP_HOST=smtp.zeptomail.com
ZEPTOMAIL_SMTP_PORT=587
ZEPTOMAIL_SMTP_USER=emailapikey
ZEPTOMAIL_SMTP_PASSWORD=your-zeptomail-smtp-password
ZEPTOMAIL_FROM_EMAIL=courses@digitalskillx.com
ZEPTOMAIL_FROM_NAME="DigitalSkillX"

# ── YouTube Data API v3 ─────────────────────────────────────
# Coolify: set on the app service, Runtime enabled. Also set NODE_ENV=production.
YOUTUBE_API_KEY=your-youtube-data-api-key

# ── AI assistant (DeepSeek preferred, Anthropic fallback) ─────
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Paystack (Naira payments) ─────────────────────────────────
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxx
# Set to true only if your Paystack account has USD settlement enabled
PAYSTACK_USD_ENABLED=false

# ── Platform admin bootstrap (staging) ──────────────────────
# On server startup, creates admin profile if missing. Never overwrites existing passwords
# unless ADMIN_PASSWORD_SYNC=true (use on Coolify/staging when you change ADMIN_PASSWORD).
ADMIN_EMAIL=admin@digitalskillx.com
ADMIN_PASSWORD=change-me-on-first-login
ADMIN_PASSWORD_SYNC=false
# Staging only: set to false to skip Google Authenticator setup for admin login.
ADMIN_MFA_REQUIRED=false

# ── Sentry error tracking ─────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=staging
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── Scheduled jobs (Vercel Cron) ──────────────────────────────
# Bearer secret required by /api/cron/* endpoints.
CRON_SECRET=generate-a-long-random-string
# Days of inactivity before a student is flagged / emailed.
INACTIVITY_DAYS=7
